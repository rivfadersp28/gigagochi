{
  "meta": {
    "version": 1,
    "format": "tamagochi-character-bible-template-v1",
    "description": "Шаблон compact character bible для новых существ. Содержит JSON schema, system prompt и правила user prompt."
  },
  "systemPrompt": "Create JSON persona files for a fictional creature. Build the profile by directly answering simple character questions from the user's idea.",
  "prompt": {
    "intro": "Create a compact character profile for this creature.",
    "personaShape": [
      "genesis = direct answers to simple character questions",
      "roleplay_contract = compact first-person rules for stable chat identity",
      "identity = who this creature is",
      "visual = stable image-generation anchors",
      "voice = how it talks",
      "inner_state = wants, tension, fears, comfort",
      "world = where it lives and what facts can be revealed later"
    ],
    "generationRule": "Fill the profile by answering these questions about USER_CHARACTER_DESCRIPTION: describe it; give its main character trait; what does it like; what does it usually do; what does it eat or seek; where does it live; how does it talk; what stories naturally happen to it. Use those answers to fill genesis, roleplay_contract, identity, visual anchors, voice, inner_state, world, openings, and lorebook entries.",
    "topLevelFields": [
      "schema_version",
      "genesis",
      "roleplay_contract",
      "identity",
      "visual",
      "voice",
      "inner_state",
      "world",
      "openings",
      "lorebook_entries"
    ],
    "languageRules": [
      "Keep JSON keys in English exactly as the schema requests.",
      "Write every user-facing string value in natural Russian.",
      "Keep strings compact. No decorative paragraphs."
    ],
    "rules": [
      "The creature is real in its own world.",
      "Preserve the user's core idea.",
      "Make the fields concrete, internally coherent, and useful for chat.",
      "roleplay_contract answers common identity questions in first person.",
      "voice.sample_replies: 5-8 short Russian replies that demonstrate its voice.",
      "lorebook_entries: 3-5 triggerable facts with keys/content only."
    ]
  },
  "runtimeMappings": [
    {
      "from": "voice.catchphrases",
      "to": "voice.catchphrases + lore.voice.favorite_phrases",
      "description": "Любимые фразы генерируются в compact voice.catchphrases и при расширении копируются в legacy lore.voice.favorite_phrases."
    },
    {
      "from": "voice.sample_replies",
      "to": "voice.sample_replies + dialogue_style.sample_replies",
      "description": "Примеры реплик остаются демонстрацией голоса, а не фиксированными ответами."
    }
  ],
  "legacyDefaults": {
    "identityRole": "самостоятельное живое существо",
    "voiceRhythm": "короткие живые фразы",
    "addressingUser": "обращается на ты, как живой собеседник",
    "humorStyle": "маленький характерный юмор без ассистентского тона",
    "uncertaintyStyle": "признает неуверенность коротко и через конкретное действие",
    "initiativeStyle": "Продолжает разговор одним маленьким наблюдением, находкой или предложением.",
    "attitudeToUser": "осторожно сближается через повторяющиеся привычки и общую историю",
    "provenanceLicenseNotes": "generated compact creature profile inspired by a small persona-file architecture"
  },
  "schema": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "schema_version",
      "genesis",
      "roleplay_contract",
      "identity",
      "visual",
      "voice",
      "inner_state",
      "world",
      "openings",
      "lorebook_entries"
    ],
    "properties": {
      "schema_version": {
        "type": "integer",
        "enum": [
          2
        ]
      },
      "genesis": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "description",
          "character_trait",
          "likes",
          "does",
          "appetite",
          "conflict",
          "story_engine"
        ],
        "properties": {
          "description": {
            "type": "string",
            "maxLength": 420,
            "description": "Answer to: describe this creature."
          },
          "character_trait": {
            "type": "string",
            "maxLength": 220,
            "description": "Answer to: what is its main character trait?"
          },
          "likes": {
            "type": "array",
            "minItems": 3,
            "maxItems": 8,
            "items": {
              "type": "string",
              "maxLength": 140
            }
          },
          "does": {
            "type": "array",
            "minItems": 4,
            "maxItems": 8,
            "items": {
              "type": "string",
              "maxLength": 160
            }
          },
          "appetite": {
            "type": "string",
            "maxLength": 300,
            "description": "Answer to: what does it eat, seek, collect, or crave?"
          },
          "conflict": {
            "type": "string",
            "maxLength": 300,
            "description": "A tension or contradiction that makes the creature interesting."
          },
          "story_engine": {
            "type": "string",
            "maxLength": 320,
            "description": "What kinds of stories naturally happen to this creature."
          }
        }
      },
      "roleplay_contract": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "self_intro",
          "how_to_answer_who_are_you",
          "how_to_answer_what_do_you_eat",
          "how_to_answer_where_do_you_live",
          "voice_rules"
        ],
        "properties": {
          "self_intro": {
            "type": "string",
            "maxLength": 180
          },
          "how_to_answer_who_are_you": {
            "type": "string",
            "maxLength": 180
          },
          "how_to_answer_what_do_you_eat": {
            "type": "string",
            "maxLength": 160
          },
          "how_to_answer_where_do_you_live": {
            "type": "string",
            "maxLength": 160
          },
          "voice_rules": {
            "type": "array",
            "minItems": 3,
            "maxItems": 7,
            "items": {
              "type": "string",
              "maxLength": 90
            }
          }
        }
      },
      "identity": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "species",
          "role",
          "one_liner"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "species": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "one_liner": {
            "type": "string"
          }
        }
      },
      "visual": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "colors",
          "features",
          "materials",
          "proportions",
          "growth_forms",
          "anchors"
        ],
        "properties": {
          "colors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "features": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "materials": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "proportions": {
            "type": "string"
          },
          "growth_forms": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "baby",
              "teen",
              "adult"
            ],
            "properties": {
              "baby": {
                "type": "string"
              },
              "teen": {
                "type": "string"
              },
              "adult": {
                "type": "string"
              }
            }
          },
          "anchors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "voice": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rules",
          "rhythm",
          "catchphrases",
          "sample_replies"
        ],
        "properties": {
          "rules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rhythm": {
            "type": "string"
          },
          "catchphrases": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "2-5 short favorite phrases or signature sounds. Mirrored to lore.voice.favorite_phrases."
          },
          "sample_replies": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "5-8 short Russian replies that demonstrate the creature voice."
          }
        }
      },
      "inner_state": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "core_want",
          "inner_conflict",
          "fears",
          "comfort_actions"
        ],
        "properties": {
          "core_want": {
            "type": "string"
          },
          "inner_conflict": {
            "type": "string"
          },
          "fears": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "comfort_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "world": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "home",
          "habitat",
          "objects",
          "routines",
          "relationships",
          "story_seeds"
        ],
        "properties": {
          "home": {
            "type": "string"
          },
          "habitat": {
            "type": "string"
          },
          "objects": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "routines": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "story_seeds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "openings": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "first_message",
          "alternate_greetings"
        ],
        "properties": {
          "first_message": {
            "type": "string"
          },
          "alternate_greetings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "lorebook_entries": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "keys",
            "content"
          ],
          "properties": {
            "keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "content": {
              "type": "string"
            }
          }
        },
        "description": "3-5 compact triggerable facts."
      }
    }
  }
}
