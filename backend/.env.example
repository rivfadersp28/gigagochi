BOT_TOKEN=
BOT_STORY_WORKERS=2
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=~openai/gpt-latest
OPENROUTER_CHARACTER_MODEL=
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_VIDEO_MODEL=bytedance/seedance-2.0
OPENROUTER_VIDEO_TIMEOUT_SECONDS=900
OPENROUTER_VIDEO_POLL_INTERVAL_SECONDS=5
GENERATION_IMAGE_WORKERS=3
GENERATION_VIDEO_WORKERS=4
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=AI Tamagotchi Telegram Mini App
WEBAPP_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3000
ALLOW_DEV_TMA_AUTH=false
ENABLE_IN_MEMORY_RATE_LIMIT=false
GENERATION_RATE_LIMIT_PER_DAY=0
CHAT_RATE_LIMIT_PER_HOUR=0
LITE_FACTS_RATE_LIMIT_PER_HOUR=0
MEMORY_RATE_LIMIT_PER_HOUR=0
TELEGRAM_DAILY_PUSH_ENABLED=false
TELEGRAM_DAILY_PUSH_INTERVAL_SECONDS=300
TELEGRAM_DAILY_PUSH_MIN_INTERVAL_SECONDS=
TELEGRAM_DAILY_PUSH_MIN_INTERVAL_HOURS=6
BACKGROUND_STORY_ENABLED=true
BACKGROUND_STORY_INTERVAL_SECONDS=300
BACKGROUND_STORY_MIN_INTERVAL_SECONDS=
BACKGROUND_STORY_MIN_INTERVAL_HOURS=6
ADMIN_PUBLISH_ENABLED=false
ADMIN_PUBLISH_GIT_REMOTE=origin
ADMIN_PUBLISH_GIT_BRANCH=main
ADMIN_PUBLISH_SSH_TARGET=
ADMIN_PUBLISH_SSH_KEY_PATH=
ADMIN_PUBLISH_REMOTE_PATH=/opt/gigagochi
ADMIN_PUBLISH_HEALTH_URL=https://gigagochi.serega.works/health
ADMIN_PUBLISH_COMMAND_TIMEOUT_SECONDS=1200
ADMIN_SYNC_FROM_SERVER_ENABLED=false

# Optional legacy fallback when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_CHARACTER_MODEL=gpt-5-nano
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=1536x1152
OPENAI_IMAGE_OUTPUT_FORMAT=png
KANDINSKY_API_KEY=
KANDINSKY_BASE_URL=https://studio.kandinskylab.ai/api
KANDINSKY_T2I_TASK_TYPE=k6-image-t2i
KANDINSKY_I2I_TASK_TYPE=k6-i2i
KANDINSKY_IMAGE_RESOLUTION=1280x768
KANDINSKY_POLL_INTERVAL_SECONDS=5
IMAGE_ASPECT_RATIO=322:540
OPENAI_CHARACTER_REASONING_EFFORT=minimal
OPENAI_CHARACTER_TIMEOUT_SECONDS=180
OPENAI_CHAT_TIMEOUT_SECONDS=90
OPENAI_IMAGE_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=0
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
