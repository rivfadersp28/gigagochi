BOT_TOKEN=
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=~openai/gpt-latest
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_SITE_URL=
OPENROUTER_APP_TITLE=AI Tamagotchi Telegram Mini App
WEBAPP_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3000
ALLOW_DEV_TMA_AUTH=false
ENABLE_IN_MEMORY_RATE_LIMIT=true

# Optional legacy fallback when AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=1536x1152
OPENAI_IMAGE_OUTPUT_FORMAT=png
OPENAI_CHARACTER_TIMEOUT_SECONDS=180
OPENAI_CHAT_TIMEOUT_SECONDS=90
OPENAI_IMAGE_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=0
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
