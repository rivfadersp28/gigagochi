BOT_TOKEN=
BOT_STORY_WORKERS=2
BOT_COMMAND_MAX_QUEUED=8
BOT_UPDATE_OFFSET_PATH=/app/data/push/bot_update_offset.json
BOT_COMMAND_INBOX_PATH=/app/data/push/bot_command_inbox.sqlite3
BOT_COMMAND_INBOX_MAX_PENDING=500
BOT_COMMAND_INBOX_MAX_PENDING_PER_CHAT=8
BOT_COMMAND_INBOX_MAX_COMPLETED=10000
BOT_COMMAND_INBOX_COMPLETED_RETENTION_SECONDS=604800
BOT_COMMAND_INBOX_LEASE_SECONDS=120
HTTP_REQUEST_MAX_BODY_BYTES=1048576
# Fail fast before long sync provider calls can occupy FastAPI's full worker pool.
HTTP_LLM_GLOBAL_CONCURRENCY=16
HTTP_LLM_PER_USER_CONCURRENCY=2
HTTP_MEDIA_GLOBAL_CONCURRENCY=4
HTTP_MEDIA_PER_USER_CONCURRENCY=1
HTTP_ADMISSION_RETRY_AFTER_SECONDS=5
AI_LOG_MAX_BYTES=10485760
AI_LOG_BACKUP_COUNT=3
GENERATED_MEDIA_CLEANUP_ENABLED=true
STORAGE_HEALTH_GENERATED_ASSETS_PATH=/app/static/generated
STORAGE_HEALTH_PUSH_DATA_PATH=/app/data/push
STORAGE_HEALTH_LOGS_PATH=/app/logs
# Text-only LLM routing. `legacy` follows AI_PROVIDER.
LLM_PROFILE=legacy
LLM_RUNTIME_PATH=data/llm_runtime.json
# Set `kandinsky` to route t2i/i2i/i2v through Kandinsky.
MEDIA_PROFILE=legacy
MEDIA_RUNTIME_PATH=data/media_runtime.json
MEDIA_CONCURRENCY_LOCK_DIR=/app/data/push/media_provider_slots
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_ACCOUNT_NAMESPACE=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_CHAT_MODEL=~openai/gpt-latest
OPENROUTER_CHARACTER_MODEL=
OPENROUTER_IMAGE_MODEL=bytedance-seed/seedream-4.5
OPENROUTER_VIDEO_MODEL=x-ai/grok-imagine-video
OPENROUTER_VIDEO_TIMEOUT_SECONDS=900
OPENROUTER_VIDEO_POLL_INTERVAL_SECONDS=5
OPENROUTER_SITE_URL=https://gigagochi.serega.works
OPENROUTER_APP_TITLE=Gigagochi

WEBAPP_URL=https://gigagochi.serega.works
BACKEND_PUBLIC_URL=https://gigagochi.serega.works
CORS_ORIGINS=["https://gigagochi.serega.works"]
ALLOW_DEV_TMA_AUTH=false

# Legacy name kept for compatibility; enables the durable SQLite rate limiter.
ENABLE_IN_MEMORY_RATE_LIMIT=true
RATE_LIMIT_STORE_PATH=/app/data/push/rate_limits.sqlite3
GENERATION_RATE_LIMIT_PER_DAY=3
INTERACTIVE_TRAVEL_RATE_LIMIT_PER_DAY=30
GENERATION_MAX_QUEUED_JOBS=40
GENERATION_JOB_STORE_PATH=/app/data/push/generation_jobs.sqlite3
# Must stay on the persistent push_data volume to resume accepted paid tasks after restart.
PROVIDER_TASK_RECEIPT_STORE_PATH=/app/data/push/provider_task_receipts.sqlite3
PROVIDER_TASK_RECEIPT_STORE_MAX_RECORDS=100000
GENERATION_JOB_STUCK_SECONDS=1800
GENERATION_JOB_LEASE_GRACE_SECONDS=300
INTERACTIVE_TRAVEL_OWNER_STORE_PATH=/app/static/generated/.private/interactive_travel_owners.sqlite3
INTERACTIVE_TRAVEL_OWNER_RETENTION_SECONDS=15552000
INTERACTIVE_TRAVEL_OWNER_MAX_RECORDS=100000
OPS_ALERTS_ENABLED=true
OPS_ALERT_TELEGRAM_IDS=[62943754]
OPS_ALERT_DEDUP_SECONDS=300
DIAGNOSTIC_TELEGRAM_IDS=[62943754]
INTERACTIVE_TRAVEL_PILOT_TELEGRAM_IDS=[62943754]
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400
CHAT_RATE_LIMIT_PER_HOUR=120
LITE_FACTS_RATE_LIMIT_PER_HOUR=120
MEMORY_RATE_LIMIT_PER_HOUR=120
PUSH_SNAPSHOT_RATE_LIMIT_PER_HOUR=60
PUSH_SNAPSHOT_ATTEMPT_RATE_LIMIT_PER_HOUR=120
PUSH_SNAPSHOT_DELETE_RATE_LIMIT_PER_HOUR=10
ADMIN_PUBLISH_ENABLED=false
TELEGRAM_DAILY_PUSH_ENABLED=true
TELEGRAM_DAILY_PUSH_INTERVAL_SECONDS=300
TELEGRAM_DAILY_PUSH_HOURS=[9,15,21]
TELEGRAM_DAILY_PUSH_WINDOW_MINUTES=120
TELEGRAM_DAILY_PUSH_DEFAULT_TIMEZONE=Europe/Moscow
BACKGROUND_STORY_ENABLED=true
BACKGROUND_STORY_INTERVAL_SECONDS=300
BACKGROUND_STORY_HOURS=[9,13,17,21]
BACKGROUND_STORY_WINDOW_MINUTES=120
# Fixed UTC 24h cap: each scheduled provider submission attempt consumes one unit.
SCHEDULED_BACKGROUND_STORY_PAID_MEDIA_DAILY_CAP=16
TELEGRAM_PUSH_STORE_PATH=/app/data/push/telegram_push_state.sqlite3
TELEGRAM_PUSH_STORE_BACKEND=auto
# Stop backend and bot together before the first deploy; import is transactional and idempotent.
TELEGRAM_PUSH_LEGACY_JSON_PATH=/app/data/push/telegram_push_state.json
# Fail closed if the expected legacy volume/file is missing during migration.
TELEGRAM_PUSH_LEGACY_JSON_REQUIRED=true
TELEGRAM_PUSH_RECORD_MAX_BYTES=1048576
TELEGRAM_PUSH_STORE_MAX_BYTES=134217728
TELEGRAM_PUSH_STORE_MAX_RECORDS=10000
TELEGRAM_PUSH_UNREACHABLE_RETENTION_SECONDS=7776000

# Required for the primary pet image lineage, regardless of MEDIA_PROFILE.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_CHARACTER_MODEL=gpt-5-nano
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_SIZE=1536x1152
OPENAI_IMAGE_OUTPUT_FORMAT=png
# Opt-in diagnostic comparison. It adds a second paid pet asset lineage.
PET_COMPARISON_ENABLED=false
# Required when an active media route or PET_COMPARISON_ENABLED uses Kandinsky.
KANDINSKY_API_KEY=
KANDINSKY_ACCOUNT_NAMESPACE=
KANDINSKY_BASE_URL=https://studio.kandinskylab.ai/api
KANDINSKY_T2I_TASK_TYPE=k6-image-t2i
KANDINSKY_I2I_TASK_TYPE=k6-i2i
KANDINSKY_I2V_TASK_TYPE=k5-i2v-hd
KANDINSKY_VIDEO_TIMEOUT_SECONDS=900
KANDINSKY_IMAGE_RESOLUTION=1280x768
KANDINSKY_PET_IMAGE_RESOLUTION=768x1280
KANDINSKY_REFERENCE_MAX_SIDE=1280
KANDINSKY_REFERENCE_JPEG_QUALITY=85
KANDINSKY_POLL_INTERVAL_SECONDS=5
IMAGE_ASPECT_RATIO=322:540
OPENAI_CHARACTER_REASONING_EFFORT=minimal
OPENAI_CHAT_REASONING_EFFORT=low
OPENAI_CHARACTER_TIMEOUT_SECONDS=180
OPENAI_CHAT_TIMEOUT_SECONDS=90
OPENAI_IMAGE_TIMEOUT_SECONDS=180
OPENAI_MAX_RETRIES=2

# Required when LLM_PROFILE=gigachat. TLS verification stays enabled by default.
GIGACHAT_BASE_URL=
GIGACHAT_USERNAME=
GIGACHAT_PASSWORD=
GIGACHAT_MODEL=GigaChat-3-Ultra
GIGACHAT_SSL_VERIFY=true
# Example custom-CA path for production Compose: /app/ca/gigachat-ca.pem
GIGACHAT_CA_BUNDLE=
GIGACHAT_TOKEN_TIMEOUT_SECONDS=30
GIGACHAT_CHAT_TIMEOUT_SECONDS=120
GIGACHAT_TOKEN_TTL_SECONDS=1500
