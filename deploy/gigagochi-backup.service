[Unit]
Description=Create and verify Gigagochi off-site backup
Wants=network-online.target
After=network-online.target docker.service

[Service]
Type=oneshot
User=root
WorkingDirectory=/opt/gigagochi
EnvironmentFile=/etc/gigagochi-backup.env
ExecStart=/opt/gigagochi/deploy/backup-nightly.sh
UMask=0077
