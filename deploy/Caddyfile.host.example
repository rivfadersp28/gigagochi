gigagochi.serega.works {
  encode zstd gzip

  handle /api/* {
    reverse_proxy gigagochi-backend:8000
  }

  handle /static/* {
    reverse_proxy gigagochi-backend:8000
  }

  handle /health {
    reverse_proxy gigagochi-backend:8000
  }

  handle {
    reverse_proxy gigagochi-frontend:3000
  }
}
